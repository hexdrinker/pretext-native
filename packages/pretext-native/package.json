{
  "name": "pretext-native",
  "version": "0.0.1",
  "description": "Pre-render text layout measurement for React Native — calculate line count, height, and line breaks before rendering",
  "main": "lib/index.js",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "types": "lib/index.d.ts",
  "files": [
    "lib",
    "src",
    "ios",
    "android",
    "pretext-native.podspec"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf lib"
  },
  "keywords": [
    "react-native",
    "text-layout",
    "text-measurement",
    "pre-render",
    "flatlist",
    "virtualization"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hexdrinker/pretext-native.git",
    "directory": "packages/pretext-native"
  },
  "homepage": "https://github.com/hexdrinker/pretext-native#readme",
  "bugs": {
    "url": "https://github.com/hexdrinker/pretext-native/issues"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0"
  },
  "dependencies": {
    "@hexdrinker/pretext-native-core": "workspace:^"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  },
  "codegenConfig": {
    "name": "PretextNativeSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.pretextnative"
    }
  }
}
