{
  "name": "pretext-native-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "example"
  ],
  "resolutions": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "scripts": {
    "build": "turbo run build --filter='!docs'",
    "test": "turbo run test --filter='!docs'",
    "typecheck": "turbo run typecheck --filter='!docs'",
    "lint": "turbo run lint --filter='!docs'",
    "docs:dev": "cd docs && yarn start",
    "docs:build": "cd docs && yarn build"
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.6.0"
}
